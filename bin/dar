#!/usr/bin/env bash
# dual-agent-review — CLI entrypoint.
#
# The command-line side of the plugin: run the review gates by hand. (The plugin runs
# the blast-radius gate automatically via hooks; these subcommands are for deliberate
# use.) Uses the Codex CLI as the reviewer; the blast-radius graph is built in pure
# Node, with graphify used as an accelerator when its graph is present and current.
#
#   dar setup    [--repo P]    install dar's skill/commands; if graphify is present,
#                              wire it into both agents and build/refresh its graph
#   dar doctor                 check the environment
#   dar probe    --repo P …    blast-radius triage only (survey vs skip), JSON
#   dar scope    --repo P --task "…"        Gate 1: survey the blast radius
#   dar plan-redteam --repo P --plan F …    Gate 2: red-team the written plan
#   dar ripple   --repo P [--baseline F | --diff-base R] [--scope-map F]
#                              Gate 4: post-diff ripple check (writes the receipt)
#   dar verify   --repo P      run the repo's configured deterministic gates
#   dar canary                 check the reviewer still catches a planted fault
#   dar trust    [--repo P] | --list       allow P's .dar.thresholds/.dar.config.sh
#   dar untrust  [--repo P]                revoke that
#   dar baseline [--repo P]    re-capture the session baseline(s) for P — use after
#                              a deliberate branch switch or large rebase
#
# Subcommands print a usage/arg error on bad input; there is no per-command --help.

set -euo pipefail

# Resolve this script's real location even when invoked through a symlink
# (install.sh symlinks bin/dar onto PATH). BSD/macOS has no `readlink -f`.
_src="${BASH_SOURCE[0]}"
while [[ -L "$_src" ]]; do
  _dir="$(cd -P "$(dirname "$_src")" && pwd)"
  _src="$(readlink "$_src")"
  [[ "$_src" != /* ]] && _src="${_dir}/${_src}"
done
DAR_HOME="$(cd -P "$(dirname "$_src")/.." && pwd)"
export DAR_HOME

cmd="${1:-}"; shift || true
case "$cmd" in
  probe)
    source "${DAR_HOME}/lib/common.sh"
    repo=""; args=()
    while [[ $# -gt 0 ]]; do
      case "$1" in --repo) repo="$2"; shift 2;; *) args+=("$1"); shift;; esac
    done
    [[ -n "$repo" ]] || { echo "dar probe: --repo required" >&2; exit 2; }
    repo="$(cd "$repo" && pwd)"; dar_load_repo_config "$repo"
    # Empty-array expansion is unbound-variable-safe on Bash 3.2 via the ${a[@]+…} guard.
    dar_probe "$repo" "${args[@]+"${args[@]}"}" --pretty
    ;;
  scope)         exec bash "${DAR_HOME}/scripts/scope.sh" "$@";;
  plan-redteam)  exec bash "${DAR_HOME}/scripts/plan-redteam.sh" "$@";;
  ripple)        exec bash "${DAR_HOME}/scripts/ripple.sh" "$@";;
  verify)        exec bash "${DAR_HOME}/scripts/verify.sh" "$@";;
  canary)        exec bash "${DAR_HOME}/scripts/canary.sh" "$@";;
  setup)         exec bash "${DAR_HOME}/scripts/setup.sh" "$@";;
  doctor)        exec bash "${DAR_HOME}/scripts/doctor.sh" "$@";;
  trust|untrust)
    # shellcheck source=/dev/null
    source "${DAR_HOME}/lib/trust.sh"
    repo="." list=0
    while [[ $# -gt 0 ]]; do
      case "$1" in --repo) repo="$2"; shift 2;; --list) list=1; shift;; *) echo "dar $cmd: unknown arg $1" >&2; exit 2;; esac
    done
    if [[ "$cmd" == "trust" && "$list" == "1" ]]; then dar_trust_list
    elif [[ "$cmd" == "trust" ]]; then dar_trust_add "$repo"
    else dar_trust_remove "$repo"
    fi
    ;;
  baseline)
    # Re-frame the session: re-capture every existing session baseline for this repo
    # at the CURRENT worktree state. Deliberate escape hatch for branch switches and
    # large rebases the Stop gate (rightly) refuses to measure — it is visible in the
    # session transcript, and anything changed AFTER re-baselining is gated again.
    # shellcheck source=/dev/null
    source "${DAR_HOME}/lib/fingerprint.sh"
    repo="."
    while [[ $# -gt 0 ]]; do
      case "$1" in --repo) repo="$2"; shift 2;; *) echo "dar baseline: unknown arg $1" >&2; exit 2;; esac
    done
    command -v node >/dev/null 2>&1 || { echo "dar baseline: node required" >&2; exit 2; }
    found=0 prev=""
    # Baselines may have been keyed on either the physical or logical project path.
    for r in "$(cd "$repo" && pwd -P)" "$(cd "$repo" && pwd -L)"; do
      [[ "$r" == "$prev" ]] && continue; prev="$r"
      key="$(dar_projkey "$r")"
      for f in "$(dar_state_dir)/baseline-${key}-"*; do
        [[ -f "$f" ]] || continue
        found=1
        if node "${DAR_HOME}/lib/baseline.mjs" capture --repo "$r" --out "$f" >/dev/null; then
          echo "re-baselined: $f"
          # Auditable by design: re-baselining excludes the CURRENT worktree state
          # from gating, so every use is recorded (like DAR_ENFORCE=off, this is a
          # deliberate, visible escape hatch — not a silent one).
          printf '%s rebaselined %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date)" "$f" \
            >> "$(dar_state_dir)/rebaseline-log-$(dar_projkey "$r")" 2>/dev/null || true
        else
          echo "dar baseline: FAILED to re-capture $f" >&2; exit 1
        fi
      done
    done
    [[ "$found" == "1" ]] || echo "dar baseline: no session baselines exist for this repo (one is captured automatically at session start)"
    ;;
  ""|-h|--help)
    sed -n '2,24p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
    ;;
  *)
    echo "dar: unknown command '$cmd' (try: doctor, probe, scope, plan-redteam, ripple, verify, canary, trust, untrust, baseline, setup)" >&2
    exit 2
    ;;
esac
