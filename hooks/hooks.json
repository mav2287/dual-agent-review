{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/bootstrap.sh"],
            "timeout": 180,
            "statusMessage": "dual-agent-review: bootstrapping…"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/prompt-advisory.sh"],
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/stop-gate.sh"],
            "timeout": 30,
            "statusMessage": "dual-agent-review: verifying review…"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "bash",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/precommit-gate.sh"],
            "timeout": 30,
            "statusMessage": "dual-agent-review: measuring blast radius…"
          },
          {
            "type": "command",
            "command": "bash",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/approve-dar.sh"],
            "timeout": 10,
            "statusMessage": "dual-agent-review: checking dar self-approval…"
          }
        ]
      }
    ]
  }
}
